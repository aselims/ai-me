        <ul class="space-y-2 text-sm">
          <li><a href="https://github.com/aselims/ai-me" target="_blank" rel="noopener noreferrer" class="text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white">GitHub</a></li>
          <li><a href="/.well-known/ai-me.json" class="text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white">Our ai-me.json</a></li>
          <li><a href="/.well-known/llms.txt" class="text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white">Our llms.txt</a></li>
        </ul>
