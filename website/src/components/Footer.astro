  <div class="mx-auto max-w-6xl px-4 py-12">
    <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
      <div>
        <h3 class="mb-3 text-sm font-semibold text-gray-900 dark:text-white">Specification</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/spec" class="text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white">Read the Spec</a></li>
          <li><a href="/quickstart" class="text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white">Quick Start</a></li>
          <li><a href="/examples" class="text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white">Examples</a></li>
          <li><a href="/validator" class="text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white">Validator</a></li>
        </ul>
      </div>
      <div>
        <h3 class="mb-3 text-sm font-semibold text-gray-900 dark:text-white">Learn</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/faq" class="text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white">FAQ</a></li>
