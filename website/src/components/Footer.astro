        </ul>
      </div>
      <div>
        <h3 class="mb-3 text-sm font-semibold text-gray-900 dark:text-white">Project</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/roadmap" class="text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white">Roadmap</a></li>
          <li><a href="/governance" class="text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white">Governance</a></li>
          <li><a href="/contributing" class="text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white">Contributing</a></li>
        </ul>
      </div>
