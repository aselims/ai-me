---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

const specs = await getCollection("spec");
const specEntry = specs[0];
let Content;
if (specEntry) {
  const rendered = await render(specEntry);
  Content = rendered.Content;
}
---

<BaseLayout title="Specification" description="AI-Me Vendor Card Specification v0.1 — the normative specification document.">
  <div class="mx-auto max-w-4xl px-4 py-12">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">AI-Me Vendor Card Specification</h1>
      <p class="mt-2 text-gray-600 dark:text-gray-400">Version 0.1 — Draft</p>
    </div>
    <article class="prose prose-gray dark:prose-invert max-w-none prose-headings:scroll-mt-20 prose-a:text-primary-600 dark:prose-a:text-primary-400 prose-code:rounded prose-code:bg-gray-100 prose-code:px-1.5 prose-code:py-0.5 dark:prose-code:bg-gray-800">
      {Content ? <Content /> : <p>Spec content not found.</p>}
    </article>
  </div>
</BaseLayout>
