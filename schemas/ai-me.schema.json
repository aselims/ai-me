{
  "$comment": "SPDX-License-Identifier: CC-BY-4.0",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://spec.ai-me.dev/schemas/ai-me.schema.json",
  "title": "AI-Me Vendor Card",
  "description": "A machine-readable vendor card for site-wide AI agent discovery (v0.1).",
  "type": "object",
  "required": [
    "schema_version",
    "name",
    "website",
    "summary",
    "canonical_pages",
    "last_updated"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1",
      "description": "Specification version. MUST be \"0.1\" for this draft."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Public-facing name of the organization or project."
    },
    "legal_name": {
      "type": "string",
      "description": "Registered legal entity name."
    },
    "website": {
      "type": "string",
      "format": "uri",
      "description": "Absolute URL of the site's primary web presence."
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "description": "Brief, plain-language description of the organization or project."
    },
    "logo": {
      "type": "string",
      "format": "uri",
      "description": "Absolute URL to a square image (min 256×256, PNG or SVG preferred)."
    },
    "languages": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-zA-Z]{2,3}(-[a-zA-Z0-9]+)*$"
      },
      "description": "BCP 47 language tags supported by the site."
    },
    "regions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Geographic regions the organization serves."
    },
    "category": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Descriptive categories for the organization or project."
    },
    "canonical_pages": {
      "type": "object",
      "required": ["home", "contact"],
      "properties": {
        "home": {
          "type": "string",
          "format": "uri",
          "description": "Absolute URL of the home page."
        },
        "contact": {
          "type": "string",
          "format": "uri",
          "description": "Absolute URL of the contact page."
        },
        "pricing": {
          "type": "string",
          "format": "uri"
        },
        "docs": {
          "type": "string",
          "format": "uri"
        },
        "privacy": {
          "type": "string",
          "format": "uri"
        },
        "terms": {
          "type": "string",
          "format": "uri"
        },
        "security": {
          "type": "string",
          "format": "uri"
        },
        "imprint": {
          "type": "string",
          "format": "uri"
        }
      },
      "additionalProperties": {
        "type": "string",
        "format": "uri"
      },
      "description": "Canonical URLs for key site pages."
    },
    "offerings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type", "description", "pricing", "cta"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": [
              "service",
              "product",
              "subscription",
              "api",
              "tool",
              "content",
              "open_source",
              "other"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "pricing": {
            "type": "object",
            "required": ["model", "currency", "url"],
            "properties": {
              "model": {
                "type": "string",
                "enum": [
                  "free",
                  "freemium",
                  "fixed",
                  "tiered",
                  "usage",
                  "quote",
                  "contact_sales",
                  "daily_rate",
                  "open_source"
                ]
              },
              "currency": {
                "type": "string",
                "description": "ISO 4217 code or empty string."
              },
              "url": {
                "type": "string",
                "description": "Absolute URL to pricing page or empty string."
              }
            },
            "additionalProperties": false
          },
          "cta": {
            "type": "object",
            "required": ["label", "url"],
            "properties": {
              "label": {
                "type": "string",
                "minLength": 1
              },
              "url": {
                "type": "string",
                "format": "uri"
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": true
      },
      "description": "Products, services, or projects offered."
    },
    "related": {
      "type": "object",
      "properties": {
        "schema_org": {
          "type": "string",
          "format": "uri",
          "description": "URL to site-level JSON-LD."
        },
        "llms_txt": {
          "type": "string",
          "format": "uri",
          "description": "URL to the site's llms.txt."
        },
        "mcp": {
          "type": "string",
          "format": "uri",
          "description": "URL to an MCP server manifest."
        },
        "a2a": {
          "type": "string",
          "format": "uri",
          "description": "URL to an A2A agent card."
        }
      },
      "additionalProperties": {
        "type": "string",
        "format": "uri"
      },
      "description": "Links to complementary structured data and protocols."
    },
    "support": {
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "hours": { "type": "string" },
        "response_time": { "type": "string" }
      },
      "additionalProperties": true,
      "description": "Support contact information."
    },
    "technical": {
      "type": "object",
      "properties": {
        "api_available": { "type": "boolean" },
        "api_docs_url": { "type": "string" },
        "status_page_url": { "type": "string" }
      },
      "additionalProperties": true,
      "description": "Technical details about the site's capabilities."
    },
    "last_updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}",
      "description": "ISO 8601 date or date-time of last update."
    }
  },
  "additionalProperties": true
}
